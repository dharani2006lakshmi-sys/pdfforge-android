PORT=3001
NODE_ENV=production

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-service-account@...iam.gserviceaccount.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS
ALLOWED_ORIGIN=https://your-netlify-domain.netlify.app

# File upload
MAX_FILE_SIZE=52428800
TEMP_DIR=/tmp/pdfforge
